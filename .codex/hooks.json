{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "git rev-parse --show-toplevel >/dev/null 2>&1 && faz init && faz onboard",
            "statusMessage": "Loading faz task context",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear|compact"
      }
    ]
  }
}
